{
  "name": "mini-agent-electron",
  "version": "1.0.0",
  "description": "Electron GUI for mini_agent — terminal-style AI coding assistant",
  "main": "main.js",
  "scripts": {
    "prestart": "node -e \"if(!require('fs').existsSync('renderer/dist/index.html')){console.log('[prestart] Building renderer...');try{require('child_process').execSync('npx --yes vite build',{stdio:'inherit',cwd:__dirname})}catch(e){console.error('[prestart] Build failed. Run: npm run build');process.exit(1)}}\"",
    "start": "electron . --no-sandbox --disable-gpu",
    "dev": "electron . --dev",
    "build": "npx vite build",
    "dev:renderer": "npx vite --config vite.config.js",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.miniagent.electron",
    "productName": "mini_agent",
    "copyright": "MIT",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/dist/**/*",
      "backend_bundle/**/*",
      "node_modules/**/*",
      "!node_modules/electron/dist/**",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.map"
    ],
    "extraResources": [
      {
        "from": "../pyinstaller_dist/mini_agent_backend",
        "to": "backend/mini_agent_backend"
      },
      {
        "from": "../pyinstaller_dist/mini_agent_backend.exe",
        "to": "backend/mini_agent_backend.exe"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "electron": "^42.2.0",
    "elkjs": "^0.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-shiki": "^0.10.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.14"
  }
}
