    {
      "type": "function",
      "function": {
        "name": "agent_handoff",
        "description": "Produce a typed structured result and route it to subscribed agents. Use this for handoffs between agents \u2014 one agent finishes work and hands structured output to another. If 'target' is set, delivers only to that task_id (bypassing subscriptions).",
