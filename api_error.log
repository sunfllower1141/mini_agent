          "properties": {},
          "required": []
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "agent_status",
        "description": "Check the status of a sub-agent without blocking. Returns 'running', 'completed' with a result summary, or 'not_found'.",
